APP_NAME=CheeseBoard Crawler
DEBUG=false

REQUEST_TIMEOUT=10.0
MAX_CONCURRENT_REQUESTS=3
RETRY_COUNT=3

STREAMERS_CSV_PATH=data/streamers.csv
OUTPUT_DIR=output

# PostgreSQL (추후 연동)
DATABASE_URL=postgresql://cheeseboard:cheeseboard@localhost:5432/cheeseboard

# Elasticsearch (추후 연동)
ELASTICSEARCH_URL=http://localhost:9200
